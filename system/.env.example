# Copy to .env (this stays local, never commit your real one).
#
# Single source of truth for local dev - both the backend (main.py) and the
# frontend dev server (vite.config.js) read this same file directly, so
# moving the backend to a different port/host only means editing the two
# values below, not hunting through code.

# LAN IP of the machine running the backend, so phones on the same WiFi can
# reach it. Find yours with `ipconfig getifaddr en0` (macOS) or `ipconfig` (Windows).
BACKEND_HOST=192.168.0.112
BACKEND_PORT=5004

# Built from the two values above - leave as-is.
VITE_API_URL=http://${BACKEND_HOST}:${BACKEND_PORT}

# Admin dashboard credentials (used to export collected game logs).
# Defaults to admin/admin if unset - fine for local dev, change before any
# public deployment.
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me

# Note: OpenAI API keys are NOT configured here.
# Each game room supplies its own key through the web interface at runtime.
